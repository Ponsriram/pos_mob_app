app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated plugin files (auto-generated, don't commit)
**/generated_plugin_registrant.*
**/generated_plugins.cmake
ios/Flutter/Debug.xcconfig
ios/Flutter/Release.xcconfig
macos/Flutter/Flutter-Debug.xcconfig
macos/Flutter/Flutter-Release.xcconfig
macos/Flutter/GeneratedPluginRegistrant.swift

# Environment files (contain secrets)
.env
.env.local
.env.*.local
*.env

# Keystore and signing
*.jks
*.keystore
key.properties
android/key.properties

# Local configuration
local.properties
android/local.properties

# IDE and editor specific
.vscode/settings.json
.vscode/launch.json
*.code-workspace

# macOS specific
*.xcuserstate
*.xcworkspace
xcuserdata/
DerivedData/

# Build outputs
*.aab
*.apk
*.ipa
*.app

# Coverage and test reports
coverage/
test-results/
*.lcov

# Logs
*.log
logs/

# Pods (iOS dependencies - can be regenerated)
ios/Pods/
ios/Podfile.lock

# Build directories
build/
.dart_tool/
.packages

# Ephemeral files (auto-generated)
